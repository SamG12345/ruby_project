<h3>New post</h3>
<div>
<%= link_to "Cancel", posts_path %>
</div>

<%= form_with model: @post do |form|%>
    <div>
        <%= form.label :title %>
        <%= form.text_field :title %>
    </div>

    <div>
        <%= form.label :body %>
        <%= form.textarea :body %>
    </div>
    <div>
        <%= form.submit %>
    </div>
<% end %>
