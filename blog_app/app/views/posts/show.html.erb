<div>
    <div>
        <%= link_to "Back", posts_path %>
        <%= link_to "Edit", edit_post_path(@post) %>
    </div>
    <div>
        <%= button_to "Delete", @post,  method: :delete, data: { turbo_confirm: "Are you sure?" } %>
    </div>
    
    <div>
        <h1> <%= @post.title %> </h1>
    </div>
    <div>
        <a> <%= @post.body %> </h1>
    </div>
</div>